NEXT_PUBLIC_API_URL=/api
API_PROXY_TARGET=https://api.nexttripholiday.com/api
NEXT_PUBLIC_WEB_URL=https://www.nexttripholiday.com

# Invoice app (SSO target). Set this to the real production invoice URL.
NEXT_PUBLIC_INVOICE_URL=https://invoices.nexttrip.work

# Secret for signing shareable manual links (7-day, no-login). Use a long random string.
MANUAL_SHARE_SECRET=change-me-to-a-long-random-string